Testing api.nft4() and api.nft6() both add rules when ipv6 is enabled.

-- Testcase --
import create_pbr from 'pbr';
let pbr = create_pbr();

// Override loadstring so user file code is actually evaluated
global.loadstring = global._orig_loadstring;

// Pre-populate the mock user file content via captured readfile
global.mocklib.capture('/usr/share/pbr/test_user.uc',
	"return function(api) {\n" +
	"	api.nft4('add element inet fw4 pbr_wan_4_dst_ip_user { 10.0.0.0/8 }');\n" +
	"	api.nft4('add element inet fw4 pbr_wan_4_dst_ip_user { 172.16.0.0/12 }');\n" +
	"	api.nft6('add element inet fw4 pbr_wan_6_dst_ip_user { 2001:db8::/32 }');\n" +
	"	api.nft6('add element inet fw4 pbr_wan_6_dst_ip_user { fd00::/8 }');\n" +
	"};\n"
);

let result = pbr.start_service(['on_start']);

let nft_content = global.mocklib.read_captured('/var/run/pbr.nft');
let checks = [];

if (nft_content) {
	// nft4 rules should be present
	push(checks, ['nft4_prefix1', index(nft_content, 'add element inet fw4 pbr_wan_4_dst_ip_user { 10.0.0.0/8 }') >= 0]);
	push(checks, ['nft4_prefix2', index(nft_content, 'add element inet fw4 pbr_wan_4_dst_ip_user { 172.16.0.0/12 }') >= 0]);

	// nft6 rules should also be present (ipv6_enabled=1)
	push(checks, ['nft6_prefix1', index(nft_content, 'add element inet fw4 pbr_wan_6_dst_ip_user { 2001:db8::/32 }') >= 0]);
	push(checks, ['nft6_prefix2', index(nft_content, 'add element inet fw4 pbr_wan_6_dst_ip_user { fd00::/8 }') >= 0]);
} else {
	push(checks, ['nft_file_written', false]);
}

let pass = 0, fail = 0;
for (let c in checks) {
	if (c[1]) {
		pass++;
	} else {
		fail++;
		printf("FAIL: %s\n", c[0]);
	}
}
printf("nft4_nft6_ipv6_enabled: %d/%d passed\n", pass, pass + fail);
-- End --

